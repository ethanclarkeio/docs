{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "DGrid AI Docs",
  "description": "Documentation for DGrid AI: The Decentralized Smart Network of AI",
  "colors": {
    "primary": "#65A30D",
    "light": "#A3E635",
    "dark": "#4D7C0F"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/dgrid-horizontal-black.png",
    "dark": "/logo/dgrid-horizontal-white.png"
  },
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "api": {
    "openapi": "api-reference/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go", "java"]
    }
  },
  "redirects": [
    {
      "source": "/ai-gateway/model-api/overview",
      "destination": "/api-reference/introduction"
    },
    {
      "source": "/ai-gateway/model-api/chat",
      "destination": "/api-reference/chat/create-chat-completion"
    },
    {
      "source": "/ai-gateway/model-api/completions",
      "destination": "/api-reference/completions/create-completion"
    },
    {
      "source": "/ai-gateway/model-api/embeddings",
      "destination": "/api-reference/embeddings/create-embedding"
    },
    {
      "source": "/ai-gateway/model-api/images",
      "destination": "/api-reference/images/create-image"
    },
    {
      "source": "/ai-gateway/model-api/audio",
      "destination": "/api-reference/audio/create-speech"
    },
    {
      "source": "/ai-gateway/model-api/moderations",
      "destination": "/api-reference/moderations/create-moderation"
    },
    {
      "source": "/ai-gateway/model-api/models",
      "destination": "/api-reference/models/list-models"
    }
  ],
